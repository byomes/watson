# Watson bot — sends notifications to Bill via Telegram.
# If WATSON_BOT_TOKEN is omitted, TELEGRAM_BOT_TOKEN is used as fallback.
WATSON_BOT_TOKEN=your_watson_bot_token_here
WATSON_CHAT_ID=your_telegram_user_id_here

# Legacy aliases (kept for backward compatibility with bot.py)
TELEGRAM_BOT_TOKEN=your_watson_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_user_id_here

# Jenny bot — briefing page buttons POST directly to this bot from the browser.
JENNY_BOT_TOKEN=your_jenny_bot_token_here
JENNY_CHAT_ID=your_telegram_user_id_here

# GitHub — pushes docs/briefing.html to the Watson repo
GITHUB_REPO=byomes/watson
GITHUB_TOKEN=your_github_personal_access_token

# WCKY site — pushes approved blog posts to the wcky site repo
WCKY_GITHUB_REPO=byomes/wcky
WCKY_GITHUB_TOKEN=your_github_personal_access_token

# Vercel — triggers redeploy after each GitHub push
VERCEL_DEPLOY_HOOK=your_vercel_deploy_hook_url

# Vercel KV — stores sermon drafts for the review app
VERCEL_KV_REST_API_URL=your_vercel_kv_rest_api_url
VERCEL_KV_REST_API_TOKEN=your_vercel_kv_rest_api_token

# Anthropic — used by cleanup.py and generate.py
ANTHROPIC_API_KEY=your_anthropic_api_key

# Kit (ConvertKit) — optional
KIT_API_KEY=your_convertkit_api_key

# Sermon pipeline — audio watch folders (Windows paths on the PC running watcher.py)
SERMON_INCOMING_DIR=E:\0 - Sermon Audio\incoming
SERMON_ARCHIVE_DIR=E:\0 - Sermon Audio\archive

# Whisper model size: tiny, base, small, medium, large (default: large)
WHISPER_MODEL=large

# Hour (24h) at which the daily briefing runs (default: 6 = 6 am)
BRIEFING_HOUR=6

# Freshness window for the briefing filter (default: 5 days)
FRESHNESS_DAYS=5

# Review app public URL
REVIEW_APP_URL=https://watson-review.vercel.app

# Daily digest email
# Comma-separated recipient addresses
DIGEST_RECIPIENTS=bill.yomes@gmail.com
# Sections to include: briefing, voice_notes, schedule, email_queue
DIGEST_SECTIONS=briefing,voice_notes,schedule
DIGEST_MAX_BRIEFING=5
DIGEST_MAX_NOTES=3
DIGEST_SUBJECT_PREFIX=Watson Daily Digest
# SMTP credentials (Gmail: use an app password, not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
# DIGEST_FROM defaults to SMTP_USER if omitted

# Connect card weekly reports
BILL_EMAIL=bill.yomes@gmail.com
DONNA_EMAIL=donna@example.com
KACI_EMAIL=kaci@example.com
# Watson Gmail account — authenticates with Gmail SMTP (smtp.gmail.com) for connect card emails
WATSON_GMAIL_ADDRESS=your_watson_gmail@gmail.com
WATSON_GMAIL_APP_PASSWORD=your_watson_gmail_app_password
# Optional Send As address — if set, used as the From header instead of WATSON_GMAIL_ADDRESS
# Requires a verified Send As alias configured in Gmail settings
WATSON_FROM_ADDRESS=watson@williamckyomes.com
